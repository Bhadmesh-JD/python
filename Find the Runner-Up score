if __name__ == '__main__':
    n = int(input())
    arr = list(map(int, input().split()))
    unique_scores = set(arr)
    sorted_unique_scores = sorted(list(unique_scores), reverse=True)
    if len(sorted_unique_scores) >= 2:
        runner_up_score = sorted_unique_scores[1]
        print(runner_up_score)
    else:
        print("Not enough unique scores to find a runner-up.")
